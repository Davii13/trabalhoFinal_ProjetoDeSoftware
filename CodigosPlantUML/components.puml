@startuml
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 40
skinparam pad 20

' ==========================================
' ESTILIZAÇÃO VISUAL APRIMORADA
' ==========================================
skinparam package {
    BackgroundColor #F8F9FA
    BorderColor #6C757D
    FontStyle bold
}
skinparam component {
    BackgroundColor #FFFFFF
    BorderColor #343A40
}
skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #0D47A1
}
skinparam queue {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}
skinparam file {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}
skinparam interface {
    BackgroundColor #FFE082
    BorderColor #FF8F00
}

title CineFlow - Sistema de Reserva de Ingressos\n(Arquitetura de Microsserviços Limpa e Alinhada)

' ==========================================
' ENTRADA DO SISTEMA
' ==========================================
component "Interface de Usuário\n(Web / Mobile)" as UI
component "API Gateway\n(Roteamento e Autenticação)" as Gateway

UI --> Gateway

' ==========================================
' MICROSSERVIÇOS (ORGANIZADOS EM PILARES VERTICAIS)
' ==========================================
package "Backend - Microsserviços Isolados" {

    ' --- PILAR 1: CATÁLOGO ---
    package "MS de Catálogo" {
        interface "API REST" as API_Cat
        file "Cat_DTO" as CatDTO
        component "Cat_Controller" as CatC
        component "Cat_Service" as CatS
        file "Cat_Model" as CatModel
        component "Cat_Repository" as CatR
        component "Cat_DAO" as CatDAO
        interface "TCP/IP" as TCP_Cat
        database "DB_Catálogo\n(PostgreSQL)" as DB_Cat

        API_Cat -down- CatC : "Fornece"
        CatC -right-> CatDTO : "Manipula"
        CatC --> CatS
        CatS -right-> CatModel : "Regras"
        CatS --> CatR
        CatR --> CatDAO
        CatDAO --> TCP_Cat
        TCP_Cat -down- DB_Cat
    }

    ' --- PILAR 2: VENDAS ---
    package "MS de Vendas" {
        interface "API REST" as API_Sales
        file "Sales_DTO" as SalesDTO
        component "Sales_Controller" as SalesC
        component "Sales_Service" as SalesS
        file "Sales_Model" as SalesModel
        queue "Broker\n(RabbitMQ / SQS)" as Broker
        component "Sales_Worker" as SalesW
        component "Sales_Repository" as SalesR
        component "Sales_DAO" as SalesDAO
        interface "TCP/IP" as TCP_Sales
        database "DB_Vendas\n(Aurora/RDS)" as DB_Sales

        API_Sales -down- SalesC : "Fornece"
        SalesC -right-> SalesDTO : "Manipula"
        SalesC --> SalesS
        SalesS -right-> SalesModel : "Regras"
        SalesS --> Broker : "Publica Evento"
        Broker --> SalesW : "Consome"
        SalesW --> SalesR
        SalesR --> SalesDAO
        SalesDAO --> TCP_Sales
        TCP_Sales -down- DB_Sales
    }

    ' --- PILAR 3: AUTENTICAÇÃO ---
    package "MS de Autenticação" {
        interface "API REST" as API_Auth
        file "Auth_DTO" as AuthDTO
        component "Auth_Controller" as AuthC
        component "Auth_Service" as AuthS
        file "Auth_Model" as AuthModel
        component "Auth_Repository" as AuthR
        component "Auth_DAO" as AuthDAO
        interface "TCP/IP" as TCP_Auth
        database "DB_Auth\n(PostgreSQL)" as DB_Auth

        API_Auth -down- AuthC : "Fornece"
        AuthC -right-> AuthDTO : "Manipula"
        AuthC --> AuthS
        AuthS -right-> AuthModel : "Regras"
        AuthS --> AuthR
        AuthR --> AuthDAO
        AuthDAO --> TCP_Auth
        TCP_Auth -down- DB_Auth
    }

    ' --- PILAR 4: PAGAMENTO ---
    package "MS de Pagamento" {
        interface "API REST" as API_Pay
        file "Pay_DTO" as PayDTO
        component "Pay_Controller" as PayC
        component "Pay_Service" as PayS
        file "Pay_Model" as PayModel
        component "Pay_Adapter" as PayAdapter
        component "Pay_Repository" as PayR
        component "Pay_DAO" as PayDAO
        interface "TCP/IP" as TCP_Pay
        database "DB_Payment\n(RDS)" as DB_Pay

        API_Pay -down- PayC : "Fornece"
        PayC -right-> PayDTO : "Manipula"
        PayC --> PayS
        PayS -right-> PayModel : "Regras"
        PayS --> PayAdapter : "Gateway Externo"
        PayS --> PayR
        PayR --> PayDAO
        PayDAO --> TCP_Pay
        TCP_Pay -down- DB_Pay
    }

    ' --- PILAR 5: NOTIFICAÇÕES ---
    package "MS de Notificações" {
        interface "API REST" as API_Notif
        file "Notif_DTO" as NotifDTO
        component "Notif_Controller" as NotifC
        component "Notif_Service" as NotifS
        file "Notif_Model" as NotifModel
        component "Notif_Worker" as NotifW
        component "Notif_Repository" as NotifR
        component "Notif_DAO" as NotifDAO
        interface "TCP/IP" as TCP_Notif
        database "DB_Notificações\n(PostgreSQL)" as DB_Notif

        API_Notif -down- NotifC : "Fornece"
        NotifC -left-> NotifDTO : "Manipula"
        NotifC --> NotifS
        NotifS -left-> NotifModel : "Regras"
        NotifS --> NotifW : "Delega Async"
        NotifW --> NotifR
        NotifR --> NotifDAO
        NotifDAO --> TCP_Notif
        TCP_Notif -down- DB_Notif
    }

    ' --- PILAR 6: BUSCA ---
    package "MS de Busca" {
        interface "API REST" as API_Search
        file "Search_DTO" as SearchDTO
        component "Search_Controller" as SearchC
        component "Search_Service" as SearchS
        file "Search_Model" as SearchModel
        component "Search_Repository" as SearchR
        component "Search_DAO" as SearchDAO
        interface "TCP/IP" as TCP_Search
        database "DB_Search\n(OpenSearch/Elastic)" as DB_Search

        API_Search -down- SearchC : "Fornece"
        SearchC -left-> SearchDTO : "Manipula"
        SearchC --> SearchS
        SearchS -left-> SearchModel : "Regras"
        SearchS --> SearchR
        SearchR --> SearchDAO
        SearchDAO --> TCP_Search
        TCP_Search -down- DB_Search
    }
}

' ==========================================
' ROTEAMENTO DO GATEWAY (Consumindo as APIs)
' ==========================================
Gateway ---> API_Cat : "/filmes"
Gateway ---> API_Sales : "/reservas"
Gateway ---> API_Auth : "/auth"
Gateway ---> API_Pay : "/pagamentos"
Gateway ---> API_Notif : "/notificacoes"
Gateway ---> API_Search : "/search"

' ==========================================
' COMUNICAÇÃO INTER-SERVIÇOS (Chamadas horizontais via API)
' ==========================================
CatS .right.> API_Sales : "Consulta disponibilidade"
SalesS .left.> API_Auth : "Valida usuário"
SalesS .down.> PayAdapter : "Solicita pagamento"
PayS .down.> NotifW : "Notifica pagamento"
SearchS .up.> API_Cat : "Sincroniza catálogo"

note right of CatS
  Responsabilidades:
  - Catálogo de filmes
  - Disponibilidade de sessões
end note

note right of SalesS
  - Gerenciar reservas
  - Regras de negócio de compra
  - Emissão de eventos para pagamento/notificação
end note

note left of PayS
  - Processamento de pagamentos
  - Integração com gateway externo
  - Registro de transações
end note

note left of NotifS
  - Enfileira e envia notificações
  - Retry / Dead-letter
  - Templates de email
end note

note right of SearchS
  - Busca full-text de filmes
  - Filtros avançados
  - Sincronização de índices
end note

@enduml
