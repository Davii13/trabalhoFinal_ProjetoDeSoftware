@startuml
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 70
left to right direction

' =====================================================
' ESTILO
' =====================================================

skinparam package {
    BackgroundColor #F8F9FA
    BorderColor #6C757D
    FontStyle bold
}

skinparam component {
    BackgroundColor white
    BorderColor #343A40
}

skinparam queue {
    BackgroundColor #FFF3E0
    BorderColor #EF6C00
}

skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}

skinparam file {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

skinparam interface {
    BackgroundColor #FFE082
    BorderColor #FF8F00
}

title CineFlow - Microsserviços Organizados\n(Spring Boot + REST + Workers + Broker)

' =====================================================
' FRONTEND
' =====================================================

package "Frontend" {

    component "Web SPA\nReact" as WEB

    component "Mobile App\nFlutter/Kotlin" as MOBILE

    component "Admin Panel\nReact Admin" as ADMIN
}

component "API Gateway\nSpring Cloud Gateway" as GATEWAY

WEB --> GATEWAY
MOBILE --> GATEWAY
ADMIN --> GATEWAY

' =====================================================
' BACKEND
' =====================================================

package "Backend - Microsserviços" {

' =====================================================
' CATÁLOGO
' =====================================================

package "MS Catálogo" {

    interface "REST API" as API_CAT

    component "CatalogController" as CAT_C

    component "CatalogService" as CAT_S

    component "CatalogRepository" as CAT_R

    queue "RabbitMQ" as CAT_Q

    component "CatalogWorker" as CAT_W

    database "CatalogDB\nPostgreSQL" as CAT_DB

    file "CatalogModel" as CAT_MODEL

    API_CAT --> CAT_C

    CAT_C --> CAT_S

    CAT_S --> CAT_R

    CAT_R --> CAT_Q

    CAT_Q --> CAT_W

    CAT_W --> CAT_DB

    CAT_S ..down..> CAT_MODEL
}

' =====================================================
' VENDAS
' =====================================================

package "MS Vendas" {

    interface "REST API" as API_SALES

    component "SalesController" as SALES_C

    component "SalesService" as SALES_S

    component "SalesRepository" as SALES_R

    queue "RabbitMQ" as SALES_Q

    component "SalesWorker" as SALES_W

    database "SalesDB\nPostgreSQL" as SALES_DB

    database "Redis Cache\nSeat Locks" as REDIS

    file "SalesModel" as SALES_MODEL

    API_SALES --> SALES_C

    SALES_C --> SALES_S

    SALES_S --> SALES_R

    SALES_R --> SALES_Q

    SALES_Q --> SALES_W

    SALES_W --> SALES_DB

    SALES_S --> REDIS : locks

    SALES_S ..down..> SALES_MODEL
}

' =====================================================
' PAGAMENTOS
' =====================================================

package "MS Pagamentos" {

    interface "REST API" as API_PAY

    component "PaymentController" as PAY_C

    component "PaymentService" as PAY_S

    component "PaymentRepository" as PAY_R

    queue "RabbitMQ" as PAY_Q

    component "PaymentWorker" as PAY_W

    database "PaymentDB\nPostgreSQL" as PAY_DB

    component "Stripe / MercadoPago" as EXT_PAY

    file "PaymentModel" as PAY_MODEL

    API_PAY --> PAY_C

    PAY_C --> PAY_S

    PAY_S --> PAY_R

    PAY_R --> PAY_Q

    PAY_Q --> PAY_W

    PAY_W --> PAY_DB

    PAY_S --> EXT_PAY

    PAY_S ..down..> PAY_MODEL
}

' =====================================================
' NOTIFICAÇÕES
' =====================================================

package "MS Notificações" {

    interface "REST API" as API_NOT

    component "NotificationController" as NOT_C

    component "NotificationService" as NOT_S

    component "NotificationRepository" as NOT_R

    queue "RabbitMQ" as NOT_Q

    component "EmailWorker" as NOT_W

    database "NotificationDB\nPostgreSQL" as NOT_DB

    component "SMTP Client\nAWS SES" as SMTP

    file "NotificationModel" as NOT_MODEL

    API_NOT --> NOT_C

    NOT_C --> NOT_S

    NOT_S --> NOT_R

    NOT_R --> NOT_Q

    NOT_Q --> NOT_W

    NOT_W --> NOT_DB

    NOT_S --> SMTP

    NOT_S ..down..> NOT_MODEL
}

' =====================================================
' VALIDAÇÃO
' =====================================================

package "MS Validação" {

    interface "REST API" as API_VAL

    component "ValidationController" as VAL_C

    component "ValidationService" as VAL_S

    component "ValidationRepository" as VAL_R

    queue "RabbitMQ" as VAL_Q

    component "ValidationWorker" as VAL_W

    database "ValidationDB\nPostgreSQL" as VAL_DB

    file "ValidationModel" as VAL_MODEL

    API_VAL --> VAL_C

    VAL_C --> VAL_S

    VAL_S --> VAL_R

    VAL_R --> VAL_Q

    VAL_Q --> VAL_W

    VAL_W --> VAL_DB

    VAL_S ..down..> VAL_MODEL
}

' =====================================================
' RELATÓRIOS
' =====================================================

package "MS Relatórios" {

    interface "REST API" as API_REL

    component "ReportController" as REL_C

    component "ReportService" as REL_S

    component "ReportRepository" as REL_R

    queue "RabbitMQ" as REL_Q

    component "AnalyticsWorker" as REL_W

    database "ReportsDB\nMongoDB" as REL_DB

    file "ReportModel" as REL_MODEL

    API_REL --> REL_C

    REL_C --> REL_S

    REL_S --> REL_R

    REL_R --> REL_Q

    REL_Q --> REL_W

    REL_W --> REL_DB

    REL_S ..down..> REL_MODEL
}

}

' =====================================================
' API GATEWAY ROUTES
' =====================================================

GATEWAY ---> API_CAT : /catalogo

GATEWAY ---> API_SALES : /vendas

GATEWAY ---> API_PAY : /pagamentos

GATEWAY ---> API_NOT : /notificacoes

GATEWAY ---> API_VAL : /validacao

GATEWAY ---> API_REL : /relatorios

' =====================================================
' COMUNICAÇÃO ENTRE SERVIÇOS
' =====================================================

SALES_S ..> API_PAY : processa pagamento

VAL_S ..> API_SALES : valida ingresso

REL_S ..> API_SALES : consulta vendas

REL_S ..> API_CAT : consulta sessões

@enduml